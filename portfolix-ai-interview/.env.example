# Portfolix AI Interview System Environment Variables

# Backend Server Configuration
PORT=5000

# MySQL Relational Database Settings (Optional: Falls back to file-based JSON DB if unconfigured)
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=portfolix_interview

# OpenAI Credentials (Required for Live Audio Whisper Transcriptions & LLM Evaluations)
# Leave blank to run the system in a responsive, mock-score fallback demonstration mode.
OPENAI_API_KEY=

# AWS S3 Cloud Storage Credentials (Optional: Falls back to server local directory if unconfigured)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
